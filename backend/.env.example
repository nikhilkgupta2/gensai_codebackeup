# DATABASE_URL=postgresql+psycopg://postgres:change_me@localhost:5432/ims

# Backend uses sync SQLAlchemy engine (psycopg driver), not asyncpg.
DATABASE_URL=postgresql+psycopg://postgres:123@localhost:5432/inventory

BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET_KEY=local-development-secret-change-before-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# SMTP email for password reset OTPs.
# Gmail development setup:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-address@gmail.com
# SMTP_PASSWORD=your-google-app-password
# SMTP_FROM_EMAIL=your-address@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
PASSWORD_RESET_OTP_EXPIRE_MINUTES=10
PASSWORD_RESET_RESEND_COOLDOWN_SECONDS=60
PASSWORD_RESET_MAX_ATTEMPTS=5
